source "https://rubygems.org"

# Local preview uses plain Jekyll 3.9 (kramdown markdown), which matches what
# GitHub Pages produces for this site and avoids native gems that don't build
# on the system Ruby 2.6. GitHub Pages builds the published site remotely.
gem "jekyll", "~> 3.9.5"
gem "kramdown-parser-gfm"
gem "ffi", "< 1.17"
gem "webrick", "~> 1.7"

group :jekyll_plugins do
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end
